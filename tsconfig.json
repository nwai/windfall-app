{
  "compilerOptions": {
    // keep your existing options, then add/tweak these:
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "strict": true,
    "types": ["vite/client"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}